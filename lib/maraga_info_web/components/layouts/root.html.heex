<!DOCTYPE html>
<html lang="en" class="scroll-smooth [scrollbar-gutter:stable]">
  <head>
    <% meta = MaragaInfoWeb.Seo.meta(assigns) %>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="csrf-token" content={get_csrf_token()} />
    <.live_title default={meta.title}>
      {assigns[:page_title]}
    </.live_title>
    <meta name="description" content={meta.description} />
    <meta name="robots" content={meta.robots} />
    <link rel="canonical" href={meta.canonical_url} />
    <link rel="icon" href={~p"/images/correct badge with correct colors.png"} sizes="any" />
    <meta property="og:site_name" content={MaragaInfoWeb.Seo.site_name()} />
    <meta property="og:title" content={meta.title} />
    <meta property="og:description" content={meta.description} />
    <meta property="og:type" content={meta.type} />
    <meta property="og:url" content={meta.canonical_url} />
    <meta property="og:image" content={meta.image_url} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={meta.title} />
    <meta name="twitter:description" content={meta.description} />
    <meta name="twitter:image" content={meta.image_url} />
    <meta
      :if={meta.published_time}
      property="article:published_time"
      content={meta.published_time}
    />
    <meta :if={meta.modified_time} property="article:modified_time" content={meta.modified_time} />
    <%= for schema <- meta.structured_data do %>
      <script type="application/ld+json">
        <%= raw(Jason.encode!(schema)) %>
      </script>
    <% end %>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous" />
    <link
      href="https://fonts.googleapis.com/css2?family=Lato:ital,wght@0,400;0,700;0,900;1,400&family=Oswald:wght@300;400;500;600;700&family=Playfair+Display:ital,wght@0,400;0,500;1,400;1,500&display=swap"
      rel="stylesheet"
    />
    <link phx-track-static rel="stylesheet" href={~p"/assets/app.css"} />
    <script defer phx-track-static type="text/javascript" src={~p"/assets/app.js"}>
    </script>
  </head>
  <body class="bg-white font-body text-grayink antialiased">
    <main>
      {@inner_content}
    </main>

    <div
      id="exit-intent-modal"
      data-exit-intent-modal
      class="fixed inset-0 z-[80] hidden items-center justify-center p-4"
      aria-hidden="true"
    >
      <div class="absolute inset-0 bg-blueink/75 backdrop-blur-sm" data-exit-intent-close></div>
      <div
        class="relative w-full max-w-xl overflow-hidden rounded-[28px] bg-white shadow-[0_30px_80px_rgba(0,0,0,0.32)]"
        role="dialog"
        aria-modal="true"
        aria-labelledby="exit-intent-title"
        aria-describedby="exit-intent-description"
      >
        <button
          type="button"
          aria-label="Close donation prompt"
          class="absolute right-4 top-4 z-10 inline-flex h-10 w-10 items-center justify-center rounded-full border border-white/30 bg-white/15 text-white transition hover:bg-white hover:text-blueink"
          data-exit-intent-close
        >
          <svg
            class="h-5 w-5"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <line x1="18" y1="6" x2="6" y2="18" />
            <line x1="6" y1="6" x2="18" y2="18" />
          </svg>
        </button>

        <div class="bg-gradient-to-r from-[#026631] via-[#0b7a3f] to-[#d61f26] px-6 pb-5 pt-6 text-white sm:px-8">
          <p class="font-head text-xs uppercase tracking-[0.35em] text-white/72">Before You Go</p>
          <h2
            id="exit-intent-title"
            class="mt-2 font-head text-2xl uppercase tracking-[0.05em] text-white sm:text-3xl"
          >
            Support the campaign
          </h2>
          <p id="exit-intent-description" class="mt-3 max-w-lg text-sm leading-6 text-white/88">
            Every contribution helps us reach more supporters, fund grassroots organizing, and carry the message of constitutional leadership across Kenya.
          </p>
        </div>

        <div class="px-6 py-6 sm:px-8 sm:py-7">
          <div class="rounded-2xl bg-[#f7faf7] p-4">
            <p class="font-head text-lg uppercase tracking-[0.08em] text-blueink sm:text-xl">
              Stand with Maraga 2027
            </p>
            <p class="mt-2 text-sm leading-6 text-slate-600">
              Make a quick donation now and help power the next stage of the movement.
            </p>
          </div>

          <div class="mt-5">
            <p class="font-head text-xs uppercase tracking-[0.2em] text-slate-500">
              Choose an amount
            </p>
            <div class="mt-3 grid grid-cols-4 gap-2">
              <%= for amount <- [50, 100, 200, 500] do %>
                <a
                  href="https://donations.davidmaraga.com/"
                  target="_blank"
                  rel="noopener"
                  class="inline-flex items-center justify-center rounded-xl border border-[#d8e5dc] bg-white px-2 py-3 font-head text-sm font-semibold text-blueink transition hover:border-[#026631] hover:bg-[#f1f8f3] hover:text-[#026631]"
                  data-exit-intent-donate
                  aria-label={"Donate KSh #{amount}"}
                >
                  KSh {amount}
                </a>
              <% end %>
            </div>
          </div>

          <div class="mt-5 flex flex-col gap-3 sm:flex-row">
            <a
              href="https://donations.davidmaraga.com/"
              target="_blank"
              rel="noopener"
              class="inline-flex items-center justify-center rounded-full bg-crimson px-6 py-4 font-head text-sm uppercase tracking-[0.2em] text-white transition hover:bg-red-700"
              data-exit-intent-donate
            >
              Donate Now
            </a>
            <button
              type="button"
              class="inline-flex items-center justify-center rounded-full border border-slate-300 px-6 py-4 font-head text-sm uppercase tracking-[0.2em] text-slate-700 transition hover:border-blueink hover:text-blueink"
              data-exit-intent-close
            >
              Continue Browsing
            </button>
          </div>
        </div>
      </div>
    </div>
  </body>
</html>
